{
  "codeConnect": {
    "parser": "react",
    "label": "React",
    "include": ["src/**/*.tsx", "src/**/*.ts"],
    "exclude": [
      "node_modules/**",
      "dist/**",
      "**/__tests__/**",
      "**/*.test.*",
      "**/*.stories.*"
    ],
    "language": "tsx",
    "importPaths": {
      "@hcl-software/enchanted-react-components/*": "./src/*"
    }
  }
}